+"""Regression tests for built-in memory overflow recovery.
+
+These tests lock in the desired runtime behavior for issue #23378:
+- when built-in memory add() overflows, the agent should run a dedicated
+  cleanup pass and retry the add once;
+- if the retry still fails, the original overflow should surface;
+- failed built-in writes must NOT be bridged to external memory providers.
+"""
+
+from __future__ import annotations
+
+import json
+from types import SimpleNamespace
+from unittest.mock import MagicMock
+
+import pytest
+
+import run_agent as run_agent_module
+from run_agent import AIAgent
+
+
+@pytest.fixture()
+def bare_agent():
+    agent = object.__new__(AIAgent)
+    agent._memory_store = object()
+    agent._memory_manager = MagicMock()
+    agent._memory_manager.on_memory_write = MagicMock()
+    agent._build_memory_write_metadata = MagicMock(return_value={"write_origin": "assistant_tool"})
+    agent._memory_enabled = True
+    agent._user_profile_enabled = True
+    agent.model = "fake-model"
+    agent.provider = "fake-provider"
+    agent.platform = "cli"
+    agent.base_url = ""
+    agent.api_key = ""
+    agent.api_mode = ""
+    agent.session_id = "sess-1"
+    agent._credential_pool = None
+    agent.background_review_callback = None
+    agent.suppress_status_output = True
+    agent.quiet_mode = True
+    agent.verbose_logging = False
+    agent._print_fn = print
+    agent._safe_print = lambda *_a, **_k: None
+    agent._current_main_runtime = lambda: {
+        "api_mode": "chat_completions",
+        "base_url": "",
+        "api_key": "",
+    }
+    agent._MEMORY_REVIEW_PROMPT = "review memory"
+    agent._SKILL_REVIEW_PROMPT = "review skills"
+    agent._COMBINED_REVIEW_PROMPT = "review both"
+    return agent
+
+
+def _overflow_result(entries=None, usage="499/500"):
+    return {
+        "success": False,
+        "error": (
+            "Memory at 499/500 chars. Adding this entry (20 chars) would exceed the limit. "
+            "Replace or remove existing entries first."
+        ),
+        "current_entries": entries or ["old fact", "stale fact"],
+        "usage": usage,
+    }
+
+
+def _success_result(message="Entry added."):
+    return {
+        "success": True,
+        "target": "memory",
+        "entries": ["trimmed fact", "new fact"],
+        "usage": "480/500",
+        "entry_count": 2,
+        "message": message,
+    }
+
+
+class FakeCleanupReviewAgent:
+    instances: list["FakeCleanupReviewAgent"] = []
+
+    def __init__(self, **kwargs):
+        self.kwargs = kwargs
+        self._session_messages = []
+        self.run_calls = []
+        FakeCleanupReviewAgent.instances.append(self)
+
+    def run_conversation(self, **kwargs):
+        self.run_calls.append(kwargs)
+        self._session_messages = [
+            {
+                "role": "tool",
+                "tool_call_id": "cleanup-1",
+                "content": json.dumps(
+                    {"success": True, "message": "Entry replaced.", "target": "memory"}
+                ),
+            }
+        ]
+
+    def shutdown_memory_provider(self):
+        pass
+
+    def close(self):
+        pass
+
+
+class ImmediateThread:
+    def __init__(self, *, target, daemon=None, name=None):
+        self._target = target
+
+    def start(self):
+        self._target()
+
+
+# ---------------------------------------------------------------------------
+# RED tests: expected behavior after the fix
+# ---------------------------------------------------------------------------
+
+
+def test_invoke_tool_memory_overflow_triggers_cleanup_and_retries_once(bare_agent, monkeypatch):
+    calls = []
+
